<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Instagram</title>
    <style>
        img {
            width: 100px;
            height: 100px;
        }
    </style>
</head>
<body>
    <h1>This page belongs to @<%= data.name %></h1>
    <button>Follow</button>
    <button>Message</button>

    <!-- <h3>Accounts that follow you : </h3>

    <ul>
        <% for(let name of followers) { %>
            <li><%= name %></li>
        <% } %>
    </ul> -->

    <p>
        Followers : <%= data.followers %> &nbsp;&nbsp;&nbsp;&nbsp; Followings : <%= 
        data.following %>    
    </p>

    <% for(let post of posts) { %>
        <img src="<%= post.image %>" alt="some img">
        <p>
            Likes : <%= post.likes %> &nbsp;&nbsp;&nbsp;&nbsp; Comments : <%= 
            post.comments %>
        </p>
    <% } %>

</body>
</html>