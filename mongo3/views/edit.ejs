<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit your chat</title>
    <style>
        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background-color: #d9daff;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
        }

        .heading {
            position: absolute;
            top: 60px;
            color: #5a3e51;
        }

        .edit-container {
            background: #a883ba;
            padding: 2.5rem;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            width: 100%;
            max-width: 450px;
        }

        h3 {
            margin-top: 0;
            color: black;
            font-size: 1.1rem;
            word-break: break-all;
            border-bottom: 1px solid #eee;
            padding-bottom: 10px;
        }

        p {
            color: black;
            font-size: 0.9rem;
            margin-bottom: 1.5rem;
        }

        textarea {
            width: 100%;
            padding: 15px;
            border: 2px solid #e1e1e1;
            border-radius: 8px;
            font-size: 1rem;
            font-family: inherit;
            resize: none; /* Prevents manual resizing */
            box-sizing: border-box;
            transition: border-color 0.3s ease;
            margin-bottom: 1.5rem;
        }

        textarea:focus {
            outline: none;
            border-color: black;
        }

        button {
            width: 100%;
            background-color: #9355b1;
            color: white;
            border: none;
            padding: 12px;
            border-radius: 8px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.3s ease, transform 0.1s ease;
        }

        button:hover {
            background-color: #873aad;
        }

        button:active {
            transform: scale(0.98);
        }
    </style>
</head>
<body>
    <h1 class="heading">Edit Chat Here..</h1>
    <div class="edit-container">
        <h3>Edit your chat: <%= chat._id %></h3>
        <p>This chat was sent from <b><%= chat.from %></b> to <b><%= chat.to %></b></p>

        <form method="POST" action="/chats/<%= chat._id %>?_method=PUT">
            <textarea name="msg" rows="6" cols="50"><%= chat.msg %></textarea>
            <button>Edit</button>
        </form>
    </div>
</body>
</html>